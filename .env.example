# sigmap-live environment variables
# Copy to .env.local for local development. Never commit .env.local.

# Google Gemini API (Google AI Studio) — powers "Ask the codebase".
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: override the model (default: gemini-2.5-flash)
GEMINI_MODEL=

# Devin API (app.devin.ai) — required to start Devin sessions
DEVIN_API_KEY=

# Optional: a GitHub token ONLY raises the anonymous rate limit for public-repo
# analysis. The demo never requires it — public repos work without it.
GITHUB_TOKEN=
