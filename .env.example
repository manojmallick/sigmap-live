# sigmap-live environment variables
# Copy to .env.local for local development. Never commit .env.local.

# Google Gemini API (Google AI Studio) — powers "Ask the codebase".
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: override the model (default: gemini-2.5-flash)
GEMINI_MODEL=

# Upstash Redis — per-IP daily rate limits (2 repos + 5 questions/day).
# Auto-injected when you add Upstash Redis from the Vercel Marketplace.
# If unset, rate limiting is disabled (fine for local dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: a GitHub token ONLY raises the anonymous rate limit for public-repo
# analysis. The demo never requires it — public repos work without it.
GITHUB_TOKEN=
